# ========== B2B PORTAL ==========
# Public-facing gateway URL — baked into the Next.js JS bundle at Docker build time.
# Browser → Next.js client-side code uses this to call the gateway directly.
# Production: https://api.yourdomain.com
# Local dev: set in b2b_portal/.env.local (auto-ignored by git), not here.
B2B_PORTAL_API_BASE_URL=http://localhost:8080

# Internal gateway URL — used by Next.js SERVER at runtime (inside Docker network).
# Next.js API routes (server-side) call http://gateway:8080 inside Docker Compose.
# On bare-metal / PM2 deploys (no Docker), set this same as B2B_PORTAL_API_BASE_URL.
B2B_PORTAL_INTERNAL_API_BASE_URL=http://gateway:8080
