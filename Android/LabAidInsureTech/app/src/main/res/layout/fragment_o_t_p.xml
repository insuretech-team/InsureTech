<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.otp.OTPFragment">


    <!-- Back Button -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_margin="16dp"
        android:src="@drawable/back_button"
        android:contentDescription="Back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="179dp"
        android:layout_height="72dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/labaid_insuretech_logo"
        android:contentDescription="Logo"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter OTP"
        android:textColor="#8E3CCB"
        android:textSize="16sp"
        android:fontFamily="@font/karla_bold"
        android:textStyle="bold"
        android:layout_marginTop="85dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="A 4 digit code has been sent to your no. +88 01721 600 000"
        android:textColor="#666666"
        android:textSize="12sp"
        android:fontFamily="@font/karla_regular"
        android:layout_marginTop="10dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.chaos.view.PinView
        android:id="@+id/otp_view"
        style="@style/PinWidget.PinView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:cursorVisible="true"
        android:gravity="center"
        android:inputType="number"
        android:itemBackground="@android:color/transparent"
        app:hideLineWhenFilled="false"
        app:itemCount="4"
        app:itemHeight="52dp"
        app:itemRadius="10dp"
        app:itemWidth="48dp"
        app:itemSpacing="12dp"
        app:lineColor="@color/otp_box_color"
        app:lineWidth="1.5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle" />


    <!-- Timer -->

    <ir.samanjafari.easycountdowntimer.EasyCountDownTextview
        android:id="@+id/easyCountDownTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:colonColor="#091d3a"
        app:digitBackground="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="@+id/otp_view"
        app:layout_constraintTop_toBottomOf="@+id/otp_view"
        app:minute="00"
        app:second="00"
        app:setAnimation="true"
        app:showDays="false"
        app:showHours="false"
        app:start_automatically="true"
        app:textColor="#242424"
        app:textSize="12sp"
        app:useFarsiNumeral="false" />

    <!-- Verify Button -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Verify"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        android:fontFamily="@font/karla_extra_bold"
        android:textAllCaps="false"
        android:enabled="false"
        android:background="@drawable/button_background"
        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/easyCountDownTextview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/did_not_receive_code"
        android:textStyle="normal"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Didn't receive code?"
        android:fontFamily="@font/karla_regular"
        app:layout_constraintEnd_toEndOf="@+id/btnVerify"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnVerify" />

    <TextView
        android:id="@+id/resend"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:text="Resend"
        android:visibility="gone"
        android:fontFamily="@font/karla_regular"
        android:textStyle="bold"
        android:textColor="@color/band_color"
        app:layout_constraintEnd_toEndOf="@id/did_not_receive_code"
        app:layout_constraintStart_toStartOf="@id/did_not_receive_code"
        app:layout_constraintTop_toBottomOf="@id/did_not_receive_code" />



</androidx.constraintlayout.widget.ConstraintLayout>