<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    tools:context=".ui.purchase_plan.PurchasePlanFragment">

    <!-- Toolbar -->
    <include
        android:id="@+id/purchase_plan_toolbar"
        layout="@layout/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/purchase_plan_toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Plan Image -->
                    <ImageView
                        android:id="@+id/ivPlanImage"
                        android:layout_width="0dp"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="Plan Image"
                        android:src="@drawable/plan_image_placeholder"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Plan Name -->
                    <TextView
                        android:id="@+id/tvPlanName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:text="Seba"
                        android:textColor="#333333"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/karla_bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivPlanImage" />

                    <!-- Coverage Info Layout -->
                    <LinearLayout
                        android:id="@+id/layoutCoverageInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvPlanName">

                        <!-- Health Coverage -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Health coverage up to"
                                android:textColor="#666666"
                                android:textSize="12sp"
                                android:fontFamily="@font/karla_regular" />

                            <TextView
                                android:id="@+id/tvCoverageAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="৳ 25,000"
                                android:textColor="#8B3FBF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/karla_bold" />

                        </LinearLayout>

                        <!-- Premium and Duration -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <!-- Premium -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_star"
                                    android:contentDescription="Premium" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Premium price:"
                                        android:textColor="#666666"
                                        android:textSize="10sp"
                                        android:fontFamily="@font/karla_regular" />

                                    <TextView
                                        android:id="@+id/tvPremiumPrice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="৳ 800"
                                        android:textColor="#333333"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:fontFamily="@font/karla_bold" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Policy Duration -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_calendar"
                                    android:tint="#8B3FBF"
                                    android:contentDescription="Duration" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Policy duration:"
                                        android:textColor="#666666"
                                        android:textSize="10sp"
                                        android:fontFamily="@font/karla_regular" />

                                    <TextView
                                        android:id="@+id/tvPolicyDuration"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1 year"
                                        android:textColor="#333333"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:fontFamily="@font/karla_bold" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Information Text -->
            <TextView
                android:id="@+id/tvInformationTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:text="Before continuing the process, we need some of your information"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/karla_bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardPlan" />

            <!-- Beneficiary Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutBeneficiary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:endIconDrawable="@drawable/ic_arrow_down"
                app:endIconTint="#666666"
                app:startIconDrawable="@drawable/ic_spouse"
                app:startIconTint="#8B3FBF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvInformationTitle">

                <AutoCompleteTextView
                    android:id="@+id/actvBeneficiary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Spouse"
                    android:inputType="none"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Name Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutBeneficiary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Name*"
                    android:inputType="textPersonName"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Date of Birth Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutDateOfBirth"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:endIconDrawable="@drawable/ic_calendar"
                app:endIconTint="#8B3FBF"
                app:endIconMode="custom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutName">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDateOfBirth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Date of Birth*"
                    android:focusable="false"
                    android:inputType="none"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Occupation Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutOccupation"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:endIconDrawable="@drawable/ic_arrow_down"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutDateOfBirth">

                <AutoCompleteTextView
                    android:id="@+id/actvOccupation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Occupation"
                    android:inputType="none"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Income Range Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutIncomeRange"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:endIconDrawable="@drawable/ic_arrow_down"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutOccupation">

                <AutoCompleteTextView
                    android:id="@+id/actvIncomeRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Income Range"
                    android:inputType="none"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mobile Number Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutMobileNo"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxStrokeColor="#E0E0E0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutIncomeRange">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMobileNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile No"
                    android:inputType="phone"
                    android:padding="16dp"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:fontFamily="@font/karla_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Upload Front NID Card -->
            <LinearLayout
                android:id="@+id/cardUploadFront"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutMobileNo">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_upload"
                    android:contentDescription="Upload" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Upload front side of your NID"
                    android:textColor="#8B3FBF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/karla_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="jpg, png file only"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:fontFamily="@font/karla_regular" />

            </LinearLayout>

            <!-- Upload Back NID Card -->
            <LinearLayout
                android:id="@+id/cardUploadBack"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardUploadFront">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_upload"
                    android:contentDescription="Upload" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Upload back side of your NID"
                    android:textColor="#8B3FBF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/karla_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="jpg, png file only"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:fontFamily="@font/karla_regular" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Continue to Pay Button (Fixed at bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueToPay"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#8B3FBF"
        android:text="Continue to Pay"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/karla_bold"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>