<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.labaid.insuretech.ui.splash.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash" >
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"
            />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.labaid.insuretech.ui.auth.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_OTPFragment"
            app:destination="@id/OTPFragment" />
    </fragment>
    <fragment
        android:id="@+id/OTPFragment"
        android:name="com.labaid.insuretech.ui.otp.OTPFragment"
        android:label="fragment_o_t_p"
        tools:layout="@layout/fragment_o_t_p" >
        <action
            android:id="@+id/action_OTPFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.labaid.insuretech.ui.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_homeFragment_to_planFragment"
            app:destination="@id/planFragment" />
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.labaid.insuretech.ui.profile.ProfileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_myInfoFragment"
            app:destination="@id/myInfoFragment" />
        <action
            android:id="@+id/action_profileFragment_to_permissionFragment"
            app:destination="@id/permissionFragment" />
    </fragment>
    <fragment
        android:id="@+id/myInfoFragment"
        android:name="com.labaid.insuretech.ui.my_info.MyInfoFragment"
        android:label="fragment_my_info"
        tools:layout="@layout/fragment_my_info" />
    <fragment
        android:id="@+id/permissionFragment"
        android:name="com.labaid.insuretech.ui.permissions.PermissionFragment"
        android:label="fragment_permission"
        tools:layout="@layout/fragment_permission" />
    <fragment
        android:id="@+id/myBeneficiaryFragment"
        android:name="com.labaid.insuretech.ui.my_beneficiary.MyBeneficiaryFragment"
        android:label="fragment_my_beneficiary"
        tools:layout="@layout/fragment_my_beneficiary" />
    <fragment
        android:id="@+id/planFragment"
        android:name="com.labaid.insuretech.ui.plan.PlanFragment"
        android:label="fragment_plan"
        tools:layout="@layout/fragment_plan" >
        <action
            android:id="@+id/action_planFragment_to_planDetailsFragment"
            app:destination="@id/planDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/planDetailsFragment"
        android:name="com.labaid.insuretech.ui.plan_details.PlanDetailsFragment"
        android:label="fragment_plan_details"
        tools:layout="@layout/fragment_plan_details" >
        <action
            android:id="@+id/action_planDetailsFragment_to_purchasePlanFragment"
            app:destination="@id/purchasePlanFragment" />
    </fragment>
    <fragment
        android:id="@+id/purchasePlanFragment"
        android:name="com.labaid.insuretech.ui.purchase_plan.PurchasePlanFragment"
        android:label="fragment_purchase_plan"
        tools:layout="@layout/fragment_purchase_plan" />
</navigation>