{
  "Kestrel": {
    "Endpoints": {
      "ProductGrpc": {
        "Url": "http://0.0.0.0:50120",
        "Protocols": "Http2"
      },
      "ProductHttp": {
        "Url": "http://0.0.0.0:50121",
        "Protocols": "Http1"
      },
      "QuoteGrpc": {
        "Url": "http://0.0.0.0:50130",
        "Protocols": "Http2"
      },
      "QuoteHttp": {
        "Url": "http://0.0.0.0:50131",
        "Protocols": "Http1"
      },
      "OrderGrpc": {
        "Url": "http://0.0.0.0:50140",
        "Protocols": "Http2"
      },
      "OrderHttp": {
        "Url": "http://0.0.0.0:50141",
        "Protocols": "Http1"
      },
      "CommissionGrpc": {
        "Url": "http://0.0.0.0:50150",
        "Protocols": "Http2"
      },
      "CommissionHttp": {
        "Url": "http://0.0.0.0:50151",
        "Protocols": "Http1"
      },
      "PolicyGrpc": {
        "Url": "http://0.0.0.0:50160",
        "Protocols": "Http2"
      },
      "PolicyHttp": {
        "Url": "http://0.0.0.0:50161",
        "Protocols": "Http1"
      },
      "UnderwritingGrpc": {
        "Url": "http://0.0.0.0:50170",
        "Protocols": "Http2"
      },
      "UnderwritingHttp": {
        "Url": "http://0.0.0.0:50171",
        "Protocols": "Http1"
      },
      "ClaimGrpc": {
        "Url": "http://0.0.0.0:50210",
        "Protocols": "Http2"
      },
      "ClaimHttp": {
        "Url": "http://0.0.0.0:50211",
        "Protocols": "Http1"
      }
    }
  },
  "ConnectionStrings": {
    "InsuranceDb": "Host=localhost;Port=5432;Database=insuretech;Username=app;Password=;SearchPath=insurance_schema",
    "CommissionDb": "Host=localhost;Port=5432;Database=insuretech;Username=app;Password=;SearchPath=commission_schema",
    "Redis": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topics": {
      "PolicyIssued": "insuretech.policy.issued.v1",
      "OrderPaymentConfirmed": "orders.order.payment_confirmed",
      "OrderPolicyProjectionIssued": "policy.issued",
      "PolicyCancelled": "insuretech.policy.cancelled.v1",
      "QuotationSubmitted": "insuretech.quotation.submitted.v1",
      "ClaimFiled": "insuretech.claim.filed.v1",
      "CommissionPayoutCreated": "insuretech.commission.payout_created.v1",
      "RenewalReminderSent": "insuretech.renewal.reminder_sent.v1"
    }
  },
  "GrpcClients": {
    "AuthnService": "http://localhost:50060",
    "AuthzService": "http://localhost:50070",
    "PartnerService": "http://localhost:50100",
    "OrdersService": "http://localhost:50142",
    "FraudService": "http://localhost:50220",
    "PaymentService": "http://localhost:50190",
    "NotificationService": "http://localhost:50230",
    "AuditService": "http://localhost:50080",
    "KycService": "http://localhost:50090",
    "StorageService": "http://localhost:50290",
    "DocgenService": "http://localhost:50280",
    "WorkflowService": "http://localhost:50180"
  },
  "InsuranceService": {
    "Url": "http://localhost:50115"
  },
  "Jwt": {
    "Issuer": "insuretech-authn",
    "Audience": "insuretech-platform",
    "PublicKeyPath": "secrets/jwt_rsa_public.pem"
  },
  "Pii": {
    "EncryptionKey": ""
  },
  "Cache": {
    "ProductTtlSeconds": 300,
    "QuotationTtlSeconds": 3600
  },
  "Commission": {
    "WithholdingTaxRate": 0.10,
    "CancellationPenaltyRate": 0.10,
    "PlatformRevenueShareRate": 0.20
  },
  "Renewal": {
    "ReminderDays": [60, 30, 7],
    "GracePeriodDays": 30,
    "SchedulerCronUtc": "5 0 * * *"
  },
  "Claims": {
    "AutoApproveThresholdPaisa": 1000000,
    "AutoApproveFraudScoreMax": 0.30,
    "FraudFlagThreshold": 0.75,
    "L1ThresholdPaisa": 5000000,
    "L2ThresholdPaisa": 20000000,
    "L3ThresholdPaisa": 50000000
  },
  "Quotation": {
    "ExpiryDays": 30
  },
  "Observability": {
    "ServiceName": "polisync",
    "OtlpEndpoint": "http://localhost:4317",
    "PrometheusPort": 9090
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Grpc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/polisync-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  }
}
