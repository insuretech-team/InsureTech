message SendOTPResponse \{ string otp_id = 1; string message = 2; int32 expires_in_seconds = 3; // 300 seconds (5 min) \}\par
// Verify OTP Request message VerifyOTPRequest \{ string otp_id = 1; string code = 2; // 6-digit code \}\par
message VerifyOTPResponse \{ bool verified = 1; string user_id = 2; string message = 3; \}\par
// Login Request message LoginRequest \{ string mobile_number = 1; string password = 2; string device_id = 3; string device_type = 4; \}\par
message LoginResponse \{ string user_id = 1; string access_token = 2; string refresh_token = 3; int32 access_token_expires_in = 4; // 900 seconds (15 min) int32 refresh_token_expires_in = 5; // 604800 seconds (7 days) entity.v1.User user = 6; \}\par
// Refresh Token Request message RefreshTokenRequest \{ string refresh_token = 1; \}\par
message RefreshTokenResponse \{ string access_token = 1; string refresh_token = 2; // New refresh token int32 access_token_expires_in = 3; int32 refresh_token_expires_in = 4; \}\par
// Logout Request message LogoutRequest \{ string session_id = 1; \}\par
message LogoutResponse \{ string message = 1; \}\par
// Change Password Request message ChangePasswordRequest \{ string user_id = 1; string old_password = 2; string new_password = 3; \}\par
message ChangePasswordResponse \{ string message = 1; \}\par
// Reset Password Request message ResetPasswordRequest \{ string mobile_number = 1; string otp_code = 2; string new_password = 3; \}\par
message ResetPasswordResponse \{ string message = 1; \}\par
// Validate Token Request message ValidateTokenRequest \{ string access_token = 1; \}\par
message ValidateTokenResponse \{ bool valid = 1; string user_id = 2; repeated string roles = 3; repeated string permissions = 4; \}\par
