// Login with credentials rpc Login(LoginRequest) returns (LoginResponse);\par
// Refresh access token rpc RefreshToken(RefreshTokenRequest) returns (RefreshTokenResponse);\par
// Logout rpc Logout(LogoutRequest) returns (LogoutResponse);\par
// Change password rpc ChangePassword(ChangePasswordRequest) returns (ChangePasswordResponse);\par
// Reset password rpc ResetPassword(ResetPasswordRequest) returns (ResetPasswordResponse);\par
// Validate token rpc ValidateToken(ValidateTokenRequest) returns (ValidateTokenResponse); \}\par
// Register Request message RegisterRequest \{ string mobile_number = 1; // Required: +880 1XXX XXXXXX string email = 2; // Optional string password = 3; // Min 8 chars, 1 upper, 1 number, 1 special string device_id = 4; string device_type = 5; \}\par
message RegisterResponse \{ string user_id = 1; string message = 2; bool otp_sent = 3; \}\par
